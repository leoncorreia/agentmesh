# ── AWS / Bedrock ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PLACEHOLDER_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=PLACEHOLDER_AWS_SECRET_ACCESS_KEY
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Redis (Redis Cloud or local) ───────────────────────────────────────────────
# Must be a full URL (redis:// or rediss://). Do not use the instance name or a path like /agentmesh_redis.
# Render: Key Value → Internal Redis URL → paste into dashboard env REDIS_URL.
REDIS_URL=PLACEHOLDER_REDIS_URL
# e.g. redis://default:password@host:6379 or rediss://... (TLS)

# ── WunderGraph ────────────────────────────────────────────────────────────────
WUNDERGRAPH_API_URL=PLACEHOLDER_WUNDERGRAPH_API_URL
WUNDERGRAPH_API_KEY=PLACEHOLDER_WUNDERGRAPH_API_KEY

# ── Ghost / TigerData ──────────────────────────────────────────────────────────
GHOST_API_URL=PLACEHOLDER_GHOST_API_URL
GHOST_CONTENT_API_KEY=PLACEHOLDER_GHOST_CONTENT_API_KEY

# ── Nexla ──────────────────────────────────────────────────────────────────────
NEXLA_API_URL=PLACEHOLDER_NEXLA_API_URL
NEXLA_API_KEY=PLACEHOLDER_NEXLA_API_KEY
NEXLA_FLOW_ID=PLACEHOLDER_NEXLA_FLOW_ID

# ── Vapi ───────────────────────────────────────────────────────────────────────
VAPI_API_KEY=PLACEHOLDER_VAPI_API_KEY
VAPI_PHONE_NUMBER_ID=PLACEHOLDER_VAPI_PHONE_NUMBER_ID
VAPI_ASSISTANT_ID=PLACEHOLDER_VAPI_ASSISTANT_ID
# Webhook URL that Vapi will POST to (your public URL, e.g. via ngrok on hack day)
VAPI_WEBHOOK_URL=PLACEHOLDER_VAPI_WEBHOOK_URL

# ── Tinyfish ───────────────────────────────────────────────────────────────────
TINYFISH_API_KEY=PLACEHOLDER_TINYFISH_API_KEY
# Optional legacy Agent API value (not required when using /automation/run-sse):
# TINYFISH_AGENT_ID=PLACEHOLDER_TINYFISH_AGENT_ID

# ── GMI Cloud (optional reasoning provider, OpenAI-compatible) ────────────────
# Base URL only (no /v1); e.g. https://api.gmi-serving.com — code calls /v1/chat/completions
GMI_API_BASE=PLACEHOLDER_GMI_API_BASE
GMI_API_KEY=PLACEHOLDER_GMI_API_KEY
GMI_MODEL=PLACEHOLDER_GMI_MODEL

# ── Insforge ───────────────────────────────────────────────────────────────────
INSFORGE_API_KEY=PLACEHOLDER_INSFORGE_API_KEY
INSFORGE_PROJECT_ID=PLACEHOLDER_INSFORGE_PROJECT_ID

# ── Akash ──────────────────────────────────────────────────────────────────────
AKASH_NODE=PLACEHOLDER_AKASH_NODE_URL
AKASH_CERT=PLACEHOLDER_AKASH_CERT_PATH

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3000
DASHBOARD_PORT=5173
NODE_ENV=development
JWT_SECRET=PLACEHOLDER_JWT_SECRET

# Core URL (agents, voice, demo)
CORE_URL=http://localhost:3000
VOICE_URL=http://localhost:3004

# Autonomous runtime
AUTONOMY_ENABLED=true
AUTONOMY_INTERVAL_SECONDS=180
# Max wait (ms) for core→remote agent HTTP /tasks (Tinyfish+LLM); default 240000
AUTONOMY_TASK_TIMEOUT_MS=240000
AUTONOMY_SOURCES=https://news.ycombinator.com/jobs,https://www.reuters.com/technology/
AUTONOMY_BRIEFING_PHONE=PLACEHOLDER_AUTONOMY_BRIEFING_PHONE
AUTONOMY_MONETIZATION_AMOUNT_USD=25

# Monetization rails
X402_ENDPOINT=PLACEHOLDER_X402_ENDPOINT
X402_API_KEY=PLACEHOLDER_X402_API_KEY
MPP_ENDPOINT=PLACEHOLDER_MPP_ENDPOINT
MPP_API_KEY=PLACEHOLDER_MPP_API_KEY
CDP_ENDPOINT=PLACEHOLDER_CDP_ENDPOINT
CDP_API_KEY=PLACEHOLDER_CDP_API_KEY
AGENTIC_MARKET_ENDPOINT=PLACEHOLDER_AGENTIC_MARKET_ENDPOINT
AGENTIC_MARKET_API_KEY=PLACEHOLDER_AGENTIC_MARKET_API_KEY

# Optional public URLs (useful for deployed dashboard)
VITE_GATEWAY_URL=PLACEHOLDER_PUBLIC_GATEWAY_URL
VITE_CORE_URL=PLACEHOLDER_PUBLIC_CORE_URL
VITE_CORE_WS_URL=PLACEHOLDER_PUBLIC_CORE_WS_URL
VITE_VOICE_URL=PLACEHOLDER_PUBLIC_VOICE_URL

# Optional: Redis URL for core integration tests (see README)
# AGENTMESH_TEST_REDIS_URL=redis://127.0.0.1:6379

# Redis Agent Memory Server (optional but recommended)
AGENT_MEMORY_API_URL=PLACEHOLDER_AGENT_MEMORY_API_URL
AGENT_MEMORY_API_KEY=PLACEHOLDER_AGENT_MEMORY_API_KEY
AGENT_MEMORY_USER_ID=agentmesh
AGENT_MEMORY_SESSION_ID=autonomy
AGENT_MEMORY_LIMIT=5

# Redis MCP (for IDE/assistant operations, not required by runtime)
REDIS_MCP_URL=PLACEHOLDER_REDIS_MCP_URL
